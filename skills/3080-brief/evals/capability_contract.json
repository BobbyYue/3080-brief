{
  "schema_version": 1,
  "context_budget": {
    "default_runtime_files": ["SKILL.md"],
    "max_skill_bytes": 15360,
    "max_skill_lines": 200,
    "retired_default_files": [
      "references/runtime-core.md",
      "references/user-supplements-rules.md",
      "docs/user-supplements-template.md",
      "scripts/sync_user_supplements.sh"
    ],
    "forbidden_default_phrases": [
      "Always read for every run",
      "Normal runs read `runtime-core.md`",
      "USER_SUPPLEMENTS_START",
      "SYNC_TO_SKILL_START"
    ]
  },
  "required_capability_ids": [
    "TRG-01",
    "SRC-01",
    "FMT-01",
    "LANG-01",
    "EVD-01",
    "TLDR-01",
    "VIS-01",
    "DEP-01",
    "REV-01",
    "RPL-01",
    "DEL-01",
    "CTX-01"
  ],
  "capabilities": [
    {
      "id": "TRG-01",
      "requirement": "Trigger aliases and non-trigger boundaries remain explicit.",
      "owner": {"file": "SKILL.md", "marker": "description: Create a new source-grounded decision brief"},
      "enforced_by": ["config/3080-brief.json", "evals/trigger_cases.json", "scripts/run_evals.py"]
    },
    {
      "id": "SRC-01",
      "requirement": "Create a new artifact and never modify the source.",
      "owner": {"file": "SKILL.md", "marker": "Create a new output. Never edit"},
      "enforced_by": ["scripts/preflight_check.py", "references/source-inventory-template.md"]
    },
    {
      "id": "FMT-01",
      "requirement": "Match output type to input type unless explicitly overridden.",
      "owner": {"file": "SKILL.md", "marker": "Match output type to input type"},
      "enforced_by": ["references/output-format-rules.md", "scripts/run_evals.py"]
    },
    {
      "id": "LANG-01",
      "requirement": "Use source primary language unless the user explicitly names another output language.",
      "owner": {"file": "config/3080-brief.json", "marker": "\"language_policy\""},
      "enforced_by": ["scripts/preflight_check.py", "evals/fixtures/inventory-en-invalid-context-zh.md", "scripts/run_evals.py"]
    },
    {
      "id": "EVD-01",
      "requirement": "Source-back claims and preserve evidence boundaries.",
      "owner": {"file": "SKILL.md", "marker": "Source-back every number"},
      "enforced_by": ["references/claim-ledger.schema.json", "references/evidence-and-risk-rules.md", "scripts/build_review_packet.py"]
    },
    {
      "id": "TLDR-01",
      "requirement": "TLDR contains one opening unit with exactly one primary judgment plus 1-3 evidence/action/boundary support lines, one picture, and one table.",
      "owner": {"file": "config/3080-brief.json", "marker": "\"tldr\""},
      "enforced_by": [
        "scripts/preflight_check.py",
        "evals/fixtures/invalid-missing-tldr.md",
        "evals/fixtures/invalid-opening-two-blocks.md",
        "evals/fixtures/invalid-opening-too-many-support-lines.md",
        "evals/fixtures/invalid-opening-no-support.xml",
        "scripts/run_evals.py"
      ]
    },
    {
      "id": "VIS-01",
      "requirement": "The visual reaches weighted coverage, preserves P0 claims, and uses quantitative encoding when required.",
      "owner": {"file": "config/3080-brief.json", "marker": "\"coverage\""},
      "enforced_by": ["scripts/check_coverage.py", "scripts/validate_visual_spec.py", "references/visual-spec.schema.json", "scripts/run_evals.py"]
    },
    {
      "id": "DEP-01",
      "requirement": "Feishu CLI, companion Skill, and executable host workflows are verified; Skill text alone is not readiness; installations and enablement require explicit approval.",
      "owner": {"file": "config/dependencies.json", "marker": "\"host_capabilities\""},
      "enforced_by": ["scripts/check_dependencies.py", "scripts/install_optional_dependencies.py", "scripts/install_skill_dependency.py", "scripts/run_evals.py"]
    },
    {
      "id": "REV-01",
      "requirement": "Use three independent hash-locked reviewers when available; otherwise run transparent role-separated self-review without stalling creation.",
      "owner": {"file": "config/3080-brief.json", "marker": "\"review_roles\""},
      "enforced_by": ["references/review-loop.md", "scripts/build_review_packet.py", "scripts/aggregate_reviews.py", "scripts/run_evals.py"]
    },
    {
      "id": "RPL-01",
      "requirement": "Blind reader replay starts after independent audit PASS; unavailable independent execution is disclosed instead of falsely claimed or used to stall creation.",
      "owner": {"file": "config/3080-brief.json", "marker": "\"blind_reader_replay\""},
      "enforced_by": ["references/blind-reader-replay.md", "scripts/run_evals.py"]
    },
    {
      "id": "DEL-01",
      "requirement": "After deterministic preflight, create before review; delivery verifies native format, language, source integrity, visual state, review status, hashes, and a real generated-output link/path.",
      "owner": {"file": "SKILL.md", "marker": "## Delivery"},
      "enforced_by": ["scripts/verify_reviewed_artifacts.py", "scripts/run_evals.py"]
    },
    {
      "id": "CTX-01",
      "requirement": "Normal runtime loads only SKILL.md within the declared context budget.",
      "owner": {"file": "evals/capability_contract.json", "marker": "\"context_budget\""},
      "enforced_by": ["scripts/check_context_budget.py", "scripts/self_test.sh"]
    }
  ]
}
